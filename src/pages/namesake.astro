---
/**
 * Namesake — the second STUDIOS mega-panel headliner.
 * Premium personal-brand sites for solo professionals: attorneys going solo,
 * performers, consultants, and individuals whose name IS the business.
 *
 * Reuses the whole LWS system (Base, Nav, Footer, Glass) and re-themes the
 * accent from cyan to brass (#C9A55A, the sanctioned Namesake token) by
 * overriding the accent custom properties on the .theme-namesake wrapper.
 *
 * HERO: the "floating photo" treatment (drifting framed portraits, animated
 * gradient, cursor-parallax orbs, readability mask) lifted from the old
 * Namesake page and re-tuned here to the brass theme + the site fonts
 * (Plus Jakarta Sans headings, IBM Plex Mono labels). Copy uses the site's
 * own .chip / .eyebrow / .btn components so it stays on-brand automatically.
 */
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Glass from "../components/Glass.astro";
import VideoBg from "../components/VideoBg.astro";

// Portrait slot -> file map (14 slots, 13 unique photos; slot 14 reuses 06,
// matching the kit's original demo arrangement).
const portraits = [
  1, 14, 10, 6, 15, 4, 7, 8, 2, 5, 9, 12, 16, 6,
].map((n, i) => ({
  slot: i + 1,
  src: `images/portraits/portrait-${String(n).padStart(2, "0")}.jpg`,
}));

const audience = [
  {
    ico: "§",
    title: "Attorneys going solo",
    body: "You left the firm. The clients you win now find you by name, not by letterhead. Your site is the first argument you make.",
  },
  {
    ico: "♪",
    title: "Performers & artists",
    body: "A booking page that reads like a press kit. Reel, dates, and reputation in one place a promoter can trust in ten seconds.",
  },
  {
    ico: "◆",
    title: "Consultants & advisors",
    body: "Independent expertise needs a home that signals it. A personal site that carries the weight your resume can't.",
  },
  {
    ico: "❖",
    title: "Founders & principals",
    body: "Sometimes the person is the brand. When your name opens doors, the site behind it should be worth walking through.",
  },
];

const approach = [
  {
    k: "01",
    title: "Your name, set in type",
    body: "We start with the one asset nobody can copy: your name. Typography, spacing, and restraint do the work that stock photography can't.",
  },
  {
    k: "02",
    title: "A narrative, not a brochure",
    body: "Your story is the differentiator. We structure the site around the arc a client actually follows: who you are, what you've done, why it matters.",
  },
  {
    k: "03",
    title: "Built to be found",
    body: "Fast, clean, AI-platformed HTML that reads well to a hiring partner and to Google alike. Your name should rank for your name.",
  },
];
---

<Base
  title="Namesake by Live Web Studios | Personal Brand Sites for Solo Professionals"
  description="Namesake builds premium personal websites for solo professionals: attorneys going solo, performers, consultants, and founders whose name is the brand. A studio of Live Web Studios."
  canonical="https://livewebstudios.com/namesake"
>
  <Nav />

  <main class="theme-namesake">
    <!-- HERO: floating photo background -->
    <section class="fh-hero" data-fh-parallax>
      <!-- Ambient animated-gradient background -->
      <div class="fh-hero__bg" aria-hidden="true"></div>

      <!-- Floating portraits (decorative) -->
      <div class="fh-portraits" aria-hidden="true">
        {portraits.map((p) => (
          <span class={`fh-portraits__p fh-portraits__p--${p.slot}`}>
            <img src={p.src} alt="" decoding="async" />
          </span>
        ))}
      </div>

      <!-- Cursor-parallax orbs -->
      <span class="fh-orb fh-orb--1" aria-hidden="true"></span>
      <span class="fh-orb fh-orb--2" aria-hidden="true"></span>
      <span class="fh-orb fh-orb--3" aria-hidden="true"></span>

      <!-- Readability mask -->
      <div class="fh-hero__mask" aria-hidden="true"></div>

      <!-- Foreground copy -->
      <div class="fh-hero__inner">
        <div class="chip"><span class="dot"></span> A STUDIO OF LIVE WEB STUDIOS</div>
        <span class="eyebrow">PERSONAL BRAND · SOLO PROFESSIONALS · BY NAME</span>
        <h1>Your name is <em>the</em> business.</h1>
        <p class="fh-lead">Namesake builds premium personal sites for people whose reputation carries the work.</p>
        <div class="fh-btn-row">
          <a href="contact.html" class="btn btn-primary">Let's talk. →</a>
          <a href="#work" class="btn btn-ghost">See the approach ↓</a>
        </div>
      </div>

      <div class="fh-scroll-cue" aria-hidden="true">
        <span class="fh-scroll-cue__line"></span>
        Scroll
      </div>
    </section>

    <!-- POSITIONING -->
    <section class="sec-pad has-videobg">
      <VideoBg src="bg-orange-beam-noaudio.mp4" scrim="default" />
      <div class="wrap">
        <Glass class="reveal" innerClass="feature">
          <span class="eyebrow is-center mb-md">WHAT NAMESAKE IS</span>
          <h2>Live Web Studios builds businesses a home. Namesake builds a person one.</h2>
          <p>Most sites sell a company. Namesake sells you. When the client is choosing a person, not a vendor, the website has a different job: carry your name, your record, and your judgment with the weight they deserve. That is the only thing we build here.</p>
        </Glass>
      </div>
    </section>

    <!-- AUDIENCE -->
    <section class="sec-pad is-alt">
      <div class="wrap">
        <div class="sec-head center reveal">
          <span class="eyebrow">WHO IT'S FOR</span>
          <h2>When the name on the door is yours.</h2>
        </div>
        <div class="grid-svc grid-svc--2">
          {audience.map((a) => (
            <div class="card reveal">
              <Glass variant="inner" innerClass="card-pad">
                <div class="ico">{a.ico}</div>
                <h3>{a.title}</h3>
                <p>{a.body}</p>
              </Glass>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- APPROACH -->
    <section id="work" class="sec-pad">
      <div class="wrap">
        <div class="sec-head center reveal">
          <span class="eyebrow">THE APPROACH</span>
          <h2>Editorial, not templated.</h2>
        </div>
        <div class="ns-steps">
          {approach.map((s) => (
            <article class="ns-step reveal">
              <span class="ns-step-k">{s.k}</span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURE / NARRATIVE -->
    <section class="sec-pad is-alt">
      <div class="wrap split">
        <div class="copy reveal">
          <span class="eyebrow">THE DIFFERENCE</span>
          <div class="sec-head is-flush"><h2>Reputation, rendered.</h2></div>
          <p>Live Web Studios has built for North Jersey businesses since 2004. Namesake is that same craft pointed at a single person: the founder, the performer, the attorney who just hung their own shingle.</p>
          <p>No page builders. No stock-photo sameness. A site that reads like it was made for one name, because it was.</p>
          <p class="kick">Your name should look like it means something. We make sure it does.</p>
          <div class="mt-lg"><a href="contact.html" class="btn btn-ghost">Reach out. →</a></div>
        </div>
        <Glass class="reveal" innerClass="portrait">
          <div class="frame-lines"></div>
          <div class="big ns-mark">Aa</div>
          <div class="mark">Namesake · A Studio of Live Web Studios</div>
        </Glass>
      </div>
    </section>

    <!-- CTA -->
    <section class="sec-pad">
      <div class="wrap">
        <Glass class="reveal" innerClass="cta">
          <h2>Ready to put your name on it?</h2>
          <p>Tell me who you are and what you're building. I'll tell you what it could look like.</p>
          <div class="hero-btns">
            <a href="contact.html" class="btn btn-primary">Let's talk. →</a>
            <a href="tel:7328019611" class="btn btn-ghost">732.801.9611</a>
          </div>
        </Glass>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Floating-hero cursor parallax (orbs only). Vanilla, respects
       prefers-reduced-motion. Photos + gradient are pure CSS and work
       without this. -->
  <script is:inline>
    (function () {
      var reduce =
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) return;
      document.querySelectorAll("[data-fh-parallax]").forEach(function (stage) {
        var orbs = stage.querySelectorAll(".fh-orb");
        if (!orbs.length) return;
        stage.addEventListener("mousemove", function (e) {
          var r = stage.getBoundingClientRect();
          var dx = (e.clientX - r.left - r.width / 2) / (r.width / 2);
          var dy = (e.clientY - r.top - r.height / 2) / (r.height / 2);
          orbs.forEach(function (orb, i) {
            var depth = (i + 1) * 10;
            orb.style.transform =
              "translate(" + dx * depth + "px," + dy * depth + "px)";
          });
        });
        stage.addEventListener("mouseleave", function () {
          orbs.forEach(function (orb) {
            orb.style.transform = "";
          });
        });
      });
    })();
  </script>
</Base>

<style>
  /* Brass sub-brand theming. Overriding the accent custom properties on the
     wrapper re-themes every descendant that reads them (buttons, eyebrows,
     glass borders, hero em, chip) with zero component forks. */
  .theme-namesake {
    --cyan: #c9a55a;          /* brass base — drives buttons, dots, eyebrow rule */
    --cyan-soft: #e3cb8b;     /* light brass — eyebrow text, hero em */
    --cyan-2: #a9863c;        /* deep brass — button gradient base */
    --cyan-deep: #4a3a12;
    --on-accent: #1a1206;     /* dark warm ink on brass surfaces (~8:1) */
    --line: rgba(201, 165, 90, 0.16);
    --line-2: rgba(201, 165, 90, 0.08);
  }

  /* Two-up audience grid (system default grid-svc is 3-up). */
  .grid-svc--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  /* Editorial numbered steps — brass keyline down the left. */
  .ns-steps {
    display: grid;
    gap: 1.25rem;
    max-width: 900px;
    margin-inline: auto;
  }
  .ns-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.6rem;
    align-items: start;
    padding: 1.6rem 1.8rem;
    border-left: 1px solid var(--line);
    background: rgba(201, 165, 90, 0.03);
    border-radius: 0 var(--r-md) var(--r-md) 0;
  }
  .ns-step-k {
    font-family: var(--mono);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--cyan-soft);
    line-height: 1;
    letter-spacing: 0.04em;
  }
  .ns-step h3 {
    font-size: 1.22rem;
    font-weight: 600;
    color: var(--ink-soft);
    margin-bottom: 0.5rem;
  }
  .ns-step p {
    color: var(--muted);
    font-size: 0.98rem;
    max-width: 60ch;
  }

  /* Editorial portrait mark — brass, serif-weight glyph instead of the JW block. */
  .ns-mark {
    color: rgba(201, 165, 90, 0.18);
    font-weight: 700;
  }

  /* ============ Floating photo hero ============
     Kit re-tuned to the brass theme and the site fonts. All markup for these
     selectors lives in this component, so Astro scopes them cleanly. Copy uses
     the global .chip / .eyebrow / .btn components (IBM Plex Mono + brass). */
  .fh-hero {
    --fh-ink: var(--bg);
    position: relative;
    min-height: clamp(620px, 92vh, 920px);
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    background: var(--fh-ink);
    color: var(--ink);
  }

  /* Ambient animated gradient — brass radials over the site base. */
  .fh-hero__bg {
    position: absolute;
    inset: -10%;
    z-index: -2;
    background:
      radial-gradient(48% 50% at 18% 28%, rgba(201, 165, 90, 0.26), transparent 60%),
      radial-gradient(46% 48% at 82% 22%, rgba(227, 203, 139, 0.16), transparent 62%),
      radial-gradient(60% 60% at 70% 88%, rgba(169, 134, 60, 0.30), transparent 64%),
      radial-gradient(50% 50% at 30% 82%, rgba(35, 26, 8, 0.55), transparent 66%),
      var(--fh-ink);
    filter: saturate(1.05);
    animation: fh-drift 26s ease-in-out infinite alternate;
  }
  @keyframes fh-drift {
    0%   { transform: scale(1) translate(0, 0); }
    50%  { transform: scale(1.08) translate(2%, -1.5%); }
    100% { transform: scale(1.04) translate(-2%, 1.5%); }
  }

  /* Floating portraits. */
  .fh-portraits { position: absolute; inset: 0; z-index: -1; overflow: hidden; pointer-events: none; }
  .fh-portraits__p {
    position: absolute; display: block; overflow: hidden;
    border: 3px solid #fff;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
    animation: fh-float 6s ease-in-out infinite; will-change: transform;
  }
  .fh-portraits__p img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    filter: contrast(1) brightness(1.05) saturate(1.05);
  }
  @keyframes fh-float {
    0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); }
    50%      { transform: translateY(-26px) rotate(var(--r, 0deg)); }
  }
  .fh-portraits__p--1  { width: 122px; height: 152px; top: 13%; left: 3%;   --r: -4deg; animation-delay: 0s; }
  .fh-portraits__p--2  { width: 98px;  height: 122px; top: 63%; left: 6%;   --r: 3deg;  animation-delay: -1s; }
  .fh-portraits__p--3  { width: 102px; height: 128px; bottom: 7%; left: 27%; --r: 2deg;  animation-delay: -2s; }
  .fh-portraits__p--4  { width: 128px; height: 160px; top: 11%; right: 5%;  --r: 4deg;  animation-delay: -1.5s; }
  .fh-portraits__p--5  { width: 108px; height: 136px; top: 44%; right: 4%;  --r: -3deg; animation-delay: -2.5s; }
  .fh-portraits__p--6  { width: 98px;  height: 122px; top: 70%; right: 15%; --r: 3deg;  animation-delay: -3.5s; }
  .fh-portraits__p--7  { width: 92px;  height: 116px; top: 22%; right: 23%; --r: -2deg; animation-delay: -4.5s; }
  .fh-portraits__p--8  { width: 84px;  height: 106px; top: 6%;  left: 41%; --r: 3deg;  animation-delay: -5s; }
  .fh-portraits__p--9  { width: 100px; height: 126px; top: 4%;  left: 20%; --r: -3deg; animation-delay: -2.2s; }
  .fh-portraits__p--10 { width: 92px;  height: 116px; bottom: 5%; left: 13%; --r: 3deg;  animation-delay: -3s; }
  .fh-portraits__p--11 { width: 104px; height: 130px; bottom: 7%; right: 7%; --r: 2deg;  animation-delay: -1.8s; }
  .fh-portraits__p--12 { width: 84px;  height: 106px; top: 8%;  right: 35%; --r: -2deg; animation-delay: -4s; }
  .fh-portraits__p--13 { width: 96px;  height: 120px; top: 42%; right: 30%; --r: 4deg;  animation-delay: -2.8s; }
  .fh-portraits__p--14 { width: 90px;  height: 114px; bottom: 24%; right: 39%; --r: -3deg; animation-delay: -5.5s; }
  @media (max-width: 720px) {
    .fh-portraits__p--3, .fh-portraits__p--7, .fh-portraits__p--8,
    .fh-portraits__p--9, .fh-portraits__p--12, .fh-portraits__p--13, .fh-portraits__p--14 { display: none; }
    .fh-portraits__p img { opacity: 0.9; }
  }
  @media (prefers-reduced-motion: reduce) { .fh-portraits__p { animation: none !important; } }

  /* Cursor-parallax orbs (brass). */
  .fh-orb {
    position: absolute; z-index: -1; border-radius: 50%;
    filter: blur(48px); opacity: 0.55; will-change: transform;
    transition: transform .35s ease-out;
  }
  .fh-orb--1 { width: 360px; height: 360px; top: 8%;  left: 6%;  background: radial-gradient(circle, rgba(201, 165, 90, 0.50), transparent 70%); }
  .fh-orb--2 { width: 300px; height: 300px; top: 18%; right: 8%; background: radial-gradient(circle, rgba(227, 203, 139, 0.36), transparent 70%); }
  .fh-orb--3 { width: 420px; height: 420px; bottom: 2%; right: 22%; background: radial-gradient(circle, rgba(169, 134, 60, 0.46), transparent 70%); }

  /* Readability mask — left scrim for the left-aligned copy, tuned to --bg. */
  .fh-hero__mask {
    position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background:
      linear-gradient(90deg, rgba(5, 7, 11, 0.94) 0%, rgba(5, 7, 11, 0.64) 38%, rgba(5, 7, 11, 0.14) 64%, transparent 82%),
      linear-gradient(180deg, rgba(5, 7, 11, 0.30) 0%, rgba(5, 7, 11, 0.08) 42%, rgba(5, 7, 11, 0.72) 100%),
      radial-gradient(120% 90% at 50% 0%, transparent 58%, rgba(5, 7, 11, 0.55) 100%);
  }

  /* Foreground copy. */
  .fh-hero__inner {
    position: relative;
    max-width: var(--wrap);
    margin: 0 auto;
    width: 100%;
    padding: clamp(120px, 16vh, 180px) clamp(1.25rem, 4vw, 2.5rem) clamp(80px, 12vh, 120px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .fh-hero__inner .chip { margin-bottom: 1.1rem; }
  .fh-hero__inner .eyebrow { margin-bottom: 0.55rem; }
  .fh-hero h1 {
    font-family: var(--sans);
    font-weight: 700;
    color: var(--ink-soft);
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0.4rem 0 0;
    max-width: 16ch;
  }
  .fh-hero h1 em { font-style: normal; color: var(--cyan-soft); }
  .fh-lead {
    font-family: var(--sans);
    color: var(--muted);
    font-size: clamp(1.02rem, 1.6vw, 1.2rem);
    line-height: 1.6;
    max-width: 52ch;
    margin-top: 1.5rem;
  }
  .fh-btn-row { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-top: 2.4rem; }

  /* Scroll cue. */
  .fh-scroll-cue {
    position: absolute; left: 50%; bottom: 26px; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    color: var(--muted-2); font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
    font-family: var(--mono);
  }
  .fh-scroll-cue__line {
    width: 1px; height: 42px;
    background: linear-gradient(180deg, var(--cyan-soft), transparent);
    animation: fh-cue 2.2s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes fh-cue { 0%, 100% { transform: scaleY(0.4); opacity: 0.4; } 50% { transform: scaleY(1); opacity: 1; } }

  @media (max-width: 900px) {
    .grid-svc--2 {
      grid-template-columns: 1fr;
    }
    .ns-step {
      padding: 1.3rem 1.4rem;
      gap: 1.1rem;
    }
  }
</style>
